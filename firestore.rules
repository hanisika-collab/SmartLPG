rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // History logs-a andha specific user mattum dhaan read/write panna mudiyum
    match /systemHistory/{userId}/logs/{logId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User profile/Gas data irundha adhukkum idhe security dhaan
    match /gasData/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}